# =========================================================
#  Video Insights 后端配置模板（.env.example）
#  使用方法：
#    1. 复制本文件为 .env       →  cp .env.example .env
#    2. 必须填好下方「模型主入口」的 3 个 LLM 参数，否则前端会直接报错、无法分析
#    3. 其余项均有默认值，按需调整；修改后重启后端（python app.py）生效
#  注：标有「默认」的项即使留空也会使用所示默认值；模型参数无任何内置默认值，必须自行填写。
# =========================================================

# ⚠️注意！ 该项目由视觉模型(VLM)驱动，下面的模型全部填写视觉模型


# API Key：必填。支持的等价变量：ARK_API_KEY / OPENAI_API_KEY / LLM_API_KEY。
# 火山引擎 Ark 形如 ark-xxxxxxxx；OpenAI 形如 sk-xxxxxxxx。
MODEL_API_KEY=
# 主模型名称。火山引擎填接入点 ID（ep-xxxx）；OpenAI 填模型名（如 gpt-4o）。
MODEL_NAME=
# 模型接口 Base URL（默认火山引擎 Ark）。
# OpenAI 官方：https://api.openai.com/v1
MODEL_BASE_URL=
# 强制指定 provider：ark / openai / openai_compatible
# 留空时按 MODEL_BASE_URL 自动推断（*.volces.com→ark，api.openai.com→openai，其余→openai_compatible）
MODEL_PROVIDER=

# ===== 风控视觉兜底（可选，仅系统管理员）=====
# 留空时自动回退到上方 MODEL_* 配置；该兜底模型必须支持图片输入（视觉模型）。
# 仅在主视觉风控模型不可用时启用。
RISK_FALLBACK_API_KEY=
RISK_FALLBACK_MODEL_NAME=
RISK_FALLBACK_MODEL_BASE_URL=

# ===== 分析参数（原前端设置面板项，现固定于此）=====
# Whisper 字幕模型级别：tiny / base / small / medium / large（默认 base）
WHISPER_MODE=large
# 视频理解模式：1=直传视频给模型分析（更准、更贵，仅 Ark 支持）；0=仅走字幕分析（默认 1）
ANALYZE_USE_VIDEO=1
# 视频模式下的抽帧频率，单位：帧/秒，范围 0.1-10（默认 1.0）
VIDEO_ANALYZE_FPS=1.0
# 低置信度步骤的「AI 看图增强」最大次数，范围 0-10（默认 10）
MAX_VISION=10
# 联网搜索工具：1=开启（仅 Ark 支持，需已开通）；0=关闭（默认 0）
WEB_SEARCH=0
# 联网搜索开通引导链接（默认火山引擎控制台；自建/其他平台可改）
WEB_SEARCH_ACTIVATION_URL=https://console.volcengine.com/common-buy/CC_content_plugin

# ===== Whisper 性能调优 =====
# 推理线程数，范围 1-16（默认取 CPU 核数，上限 8）
WHISPER_THREADS=
# 计算设备：cpu / cuda / auto（默认 auto）
WHISPER_DEVICE=cpu
# 精度：int8 / int8_float16 / float16 / float32（默认 int8，CPU 友好）
WHISPER_COMPUTE_TYPE=int8
# beam search 宽度，范围 1-10（默认 5，越大越准越慢；large 模型建议 ≥5）
WHISPER_BEAM_SIZE=5
# 是否启用 VAD 过滤静音段：1=开启（默认）；0=关闭
WHISPER_VAD_FILTER=1
# 候选采样宽度，范围 1-10（默认 5，配合 beam search 提升准确率）
WHISPER_BEST_OF=5
# 是否基于上文条件解码：0=关闭（默认，强力抑制长静音处的循环幻觉）；1=开启
WHISPER_CONDITION_ON_PREVIOUS_TEXT=0
# 压缩比阈值，超过判为幻觉重复并丢弃，范围 1.0-10.0（默认 2.4）
WHISPER_COMPRESSION_RATIO_THRESHOLD=2.4
# 无语音概率阈值，范围 0.0-1.0（默认 0.6，越高越易判为静音）
WHISPER_NO_SPEECH_THRESHOLD=0.6
# 领域热词/术语提示，注入后显著改善专有名词识别（默认空）。
# 示例：WHISPER_INITIAL_PROMPT=以下是关于微信、小红书、牛客网等求职平台的操作讲解。
WHISPER_INITIAL_PROMPT=
# 【方案A】解码热词偏置（比 INITIAL_PROMPT 更稳，不随长视频衰减）。
# 逗号/空格分隔的正确词，专治同音字（如把"铁子"识别成"帖子"）。默认空。
# 示例：WHISPER_HOTWORDS=帖子,点赞,转发,关注,收藏,主页,私信,牛客网
WHISPER_HOTWORDS=
# 温度回退阶梯，逗号分隔，0.0-1.0（默认 0.0,0.2,0.4，解码失败时逐级重试）
WHISPER_TEMPERATURES=0.0,0.2,0.4
# 【方案B】ASR 前音频降噪+响度归一化：1=开启（嘈杂/带BGM素材提升明显，略慢）；0=关闭（默认）
WHISPER_PREPROCESS_AUDIO=0

# ===== 字幕 LLM 同音字纠错（默认开启，上下文感知，需调用模型）=====
# 总开关：1=字幕生成后自动跑一次 LLM 同音字纠错（默认开启，有 token 成本）；0=关闭
SUBTITLE_LLM_CORRECT=1
# 纠错时提示模型的正确术语（逗号分隔），辅助判断同音字。默认空。
# 示例：SUBTITLE_CORRECT_GLOSSARY=帖子,点赞,牛客网,在线笔试
SUBTITLE_CORRECT_GLOSSARY=
# 纠错复查日志（JSONL，每行一条修正：原文/纠正后/分词/词级对照）。默认 outputs/subtitle_corrections.jsonl
SUBTITLE_CORRECTION_LOG=
# 自学习热词表（纯文本，每行一个正确词，自动回灌方案A的 hotwords）。默认 outputs/hotwords_glossary.txt
WHISPER_HOTWORDS_FILE=

# ===== 截图质量 =====
# 多候选帧清晰度优选：1=开启（默认，在关键时刻附近采样多帧挑最清晰的）；0=关闭直采单帧
SCREENSHOT_SHARPNESS_SELECT=1

# ===== PDF 渲染 =====
# PDF 渲染引擎：auto=优先 Playwright(Chromium) 高保真渲染，不可用时自动回退 FPDF（默认）；
#               fpdf=强制使用 FPDF 逐行渲染（无需 Chromium）。
# 使用 Playwright 需先安装浏览器：python -m playwright install chromium
PDF_RENDER_ENGINE=auto

# ===== 并发与性能 =====
# 步骤截图并发数（默认 2，受 CPU 核数限制）
SCREENSHOT_MAX_WORKERS=2
# 批量分析并发数，范围 1-16（默认 2）
BATCH_ANALYZE_MAX_WORKERS=2
# 视觉增强（AI 看图）并发数，范围 1-8（默认 4）
VISION_MAX_CONCURRENCY=4
# 长视频预处理（自动压缩/切片）：1=开启（默认）；0=关闭
LONG_VIDEO_PREPROCESS_ENABLED=1

# ===== 风控参数 =====
# 视觉风控基础抽帧数（默认 4）
RISK_MAX_FRAMES=4
# 视觉风控动态抽帧上限（默认 8，不小于 RISK_MAX_FRAMES）
RISK_DYNAMIC_MAX_FRAMES=8

# ===== 服务 =====
# 监听地址（默认 127.0.0.1，对外提供服务可设为 0.0.0.0）
HOST=127.0.0.1
# 监听端口（默认 5000）
PORT=5000
# 1=Flask 开发服务器（带热重载）；0=Waitress 生产模式（默认 0）
FLASK_DEBUG=0
# Waitress 工作线程数，范围 1-64（默认 4）
WAITRESS_THREADS=4
# Waitress 最大并发连接数，范围 1-10000（默认 100）
WAITRESS_CONNECTION_LIMIT=100

# ===== 安全 =====
# Flask 会话签名密钥；留空时启动自动生成随机值（重启后旧会话失效）
FLASK_SECRET_KEY=
# SSRF 防护：是否允许 URL 导入访问内网/保留地址。
# 0=禁止（默认，推荐）；1=允许（仅在明确信任的内网部署场景使用）
URL_IMPORT_ALLOW_PRIVATE_HOSTS=0

# ===== URL 导入 / 抓取（可选，按需配置）=====
# 抓取模式：auto / static / dynamic（默认 auto）
SCRAPE_FETCH_MODE=auto
# 抓取超时秒数，范围 5-120（默认 45）
SCRAPE_TIMEOUT_SECONDS=45
# 抓取重试次数，范围 0-5（默认 3）
SCRAPE_RETRIES=3
# 是否启用模型辅助解析 HTML 候选视频：1=开启（默认）；0=关闭
SCRAPE_MODEL_PARSE_ENABLED=1
# 抓取代理（如 http://127.0.0.1:7890），留空不使用
SCRAPE_PROXY_URL=
# 抓取专用模型凭证（留空时回退到 MODEL_* / RISK_FALLBACK_*）
SCRAPE_MODEL_API_KEY=
SCRAPE_MODEL_NAME=
SCRAPE_MODEL_BASE_URL=

# ===== yt-dlp（可选，下载受限平台视频时使用）=====
# 优先从浏览器导入 cookies：1=开启（默认）；0=关闭
YTDLP_PREFER_BROWSER_COOKIES=1
# 指定浏览器来源（如 chrome / edge），留空则按候选列表尝试
YTDLP_COOKIES_FROM_BROWSER=
# 候选浏览器列表（默认 chrome,edge）
YTDLP_BROWSER_FALLBACKS=chrome,edge
# Netscape 格式 cookies 文件路径，留空不使用
YTDLP_COOKIES_FILE=

